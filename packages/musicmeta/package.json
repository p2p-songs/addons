{
  "name": "@p2p-songs/musicmeta",
  "version": "0.1.0",
  "description": "The p2p-songs metadata addon: MusicBrainz-backed catalog (search) + meta (artist/album/track), with Cover Art Archive posters. The music equivalent of Cinemeta.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "musicmeta": "./dist/serve.js"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node dist/serve.js"
  },
  "dependencies": {
    "@p2p-songs/addon-sdk": "link:../../../addon-sdk/packages/sdk",
    "@p2p-songs/musicbrainz": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
